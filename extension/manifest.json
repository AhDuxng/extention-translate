{
  "manifest_version": 3,
  "name": "Quick Viet Translator",
  "version": "1.1.0",
  "description": "Bôi đen từ để dịch ngay. Hỗ trợ EN↔VI, streaming, auto-detect.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://quick-viet-translator-backend.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
